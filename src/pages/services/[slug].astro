---
import Layout from "../../layouts/Layout.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const index = services.findIndex((s) => s.slug === service.slug);
const others = services.filter((s) => s.slug !== service.slug);
---

<Layout
  title={`${service.title} — Caxten Engineering`}
  description={service.summary}
>
  <article class="service-page">
    <!-- Hero -->
    <header class="sp-hero">
      <div class="sp-hero-bg" aria-hidden="true">
        <img src={service.image} alt="" fetchpriority="high" />
        <div class="sp-hero-overlay"></div>
        <div class="sp-hero-grid"></div>
      </div>
      <div class="container sp-hero-inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/#services">Services</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{service.title}</span>
        </nav>

        <div class="sp-hero-mark">
          <span class="sp-hero-icon" aria-hidden="true" set:html={service.icon} />
          <span class="sp-hero-index">
            Service {service.n} / {String(services.length).padStart(2, "0")}
          </span>
        </div>

        <h1 class="sp-title">{service.title}</h1>
        <p class="sp-tagline">{service.tagline}</p>
      </div>
    </header>

    <!-- Overview -->
    <section class="section sp-overview">
      <div class="container sp-overview-grid">
        <div class="sp-overview-head" data-reveal>
          <span class="kicker">Overview</span>
          <h2 class="section-title">What this covers</h2>
        </div>
        <div class="sp-overview-body" data-reveal>
          <p>{service.overview}</p>
          <a href="/contact" class="btn btn-primary sp-cta">
            Discuss your project
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Scope + deliverables -->
    <section class="section sp-scope">
      <div class="container sp-scope-layout">
        <div data-reveal>
          <span class="kicker">Scope of works</span>
          <h2 class="section-title">Delivered as a coordinated package</h2>
          <div class="sp-scope-grid">
            {
              service.scope.map((item, i) => (
                <div class="sp-scope-card">
                  <span class="sp-scope-num">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <p>{item}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="sp-deliverables" data-reveal>
          <h3>You receive</h3>
          <ul>
            {
              service.deliverables.map((d) => (
                <li>
                  <span class="check" aria-hidden="true">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.6"><path d="M20 6 9 17l-5-5" /></svg>
                  </span>
                  {d}
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </section>

    <!-- Other services -->
    <section class="section sp-others">
      <div class="container">
        <div class="sp-others-head" data-reveal>
          <span class="kicker">Keep exploring</span>
          <h2 class="section-title">The rest of our capability</h2>
        </div>
        <div class="sp-others-grid">
          {
            others.map((s) => (
              <a class="sp-other-card" href={`/services/${s.slug}`} data-reveal>
                <span class="sp-other-icon" aria-hidden="true" set:html={s.icon} />
                <h3>{s.title}</h3>
                <p>{s.summary}</p>
                <span class="sp-other-more">
                  Learn more
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  /* Hero ------------------------------------------------------------ */
  .sp-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 58vh;
    padding-top: 8rem;
    padding-bottom: 3.5rem;
    overflow: hidden;
    color: var(--on-navy);
  }

  .sp-hero-bg,
  .sp-hero-bg img,
  .sp-hero-overlay,
  .sp-hero-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .sp-hero-bg img {
    object-fit: cover;
  }

  .sp-hero-overlay {
    background: linear-gradient(
        180deg,
        rgba(6, 13, 24, 0.55),
        rgba(6, 13, 24, 0.88)
      ),
      linear-gradient(90deg, rgba(11, 37, 69, 0.9), rgba(11, 37, 69, 0.4));
  }

  .sp-hero-grid {
    background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  .sp-hero-inner {
    position: relative;
    z-index: 1;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8ba1bc;
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: #a9bcd6;
  }

  .breadcrumb a:hover {
    color: #ffffff;
  }

  .breadcrumb [aria-current] {
    color: #eef4fb;
  }

  .sp-hero-mark {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .sp-hero-icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(26, 99, 214, 0.28);
    border: 1px solid rgba(120, 170, 255, 0.35);
    color: #dbe6f7;
  }

  .sp-hero-index {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .sp-title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 650;
    color: #eef4fb;
    letter-spacing: -0.015em;
    max-width: 18ch;
  }

  .sp-tagline {
    max-width: 52ch;
    margin-top: 1.1rem;
    font-size: 1.15rem;
    color: #a9bcd6;
  }

  /* Overview -------------------------------------------------------- */
  .sp-overview-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .sp-overview-head {
    position: sticky;
    top: 6rem;
  }

  .sp-overview-body p {
    margin: 0 0 2rem;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text);
    max-width: 60ch;
  }

  .sp-cta {
    justify-self: start;
  }

  /* Scope ----------------------------------------------------------- */
  .sp-scope {
    background: var(--surface-2);
    transition: background-color 0.35s ease;
  }

  .sp-scope-layout {
    display: grid;
    grid-template-columns: 1.4fr 0.85fr;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: start;
  }

  .sp-scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .sp-scope-card {
    padding: 1.3rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    box-shadow: var(--card-shadow);
  }

  .sp-scope-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--blue);
  }

  .sp-scope-card p {
    margin: 0.5rem 0 0;
    color: var(--heading);
    font-weight: 500;
    font-size: 1rem;
  }

  .sp-deliverables {
    padding: 1.8rem;
    background: var(--navy);
    border-radius: var(--r-md);
    color: #c2d1e4;
    box-shadow: var(--card-shadow);
    position: sticky;
    top: 6rem;
  }

  .sp-deliverables h3 {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5b9bff;
    margin-bottom: 1.2rem;
  }

  .sp-deliverables ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .sp-deliverables li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 1rem;
    color: #eef4fb;
  }

  .sp-deliverables .check {
    flex: none;
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: rgba(91, 155, 255, 0.18);
    color: #5b9bff;
  }

  /* Other services -------------------------------------------------- */
  .sp-others-head {
    margin-bottom: 2.4rem;
  }

  .sp-others-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.1rem;
  }

  .sp-other-card {
    display: block;
    padding: 1.6rem 1.5rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    box-shadow: var(--card-shadow);
    color: inherit;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .sp-other-card:hover {
    transform: translateY(-4px);
    border-color: var(--blue);
  }

  .sp-other-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 12px;
    background: var(--blue-soft);
    color: var(--blue);
  }

  .sp-other-card h3 {
    font-size: 1.22rem;
    margin: 1.1rem 0 0.5rem;
  }

  .sp-other-card p {
    font-size: 0.98rem;
    color: var(--text-muted);
  }

  .sp-other-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--blue);
  }

  .sp-other-more svg {
    transition: transform 0.25s ease;
  }

  .sp-other-card:hover .sp-other-more svg {
    transform: translateX(4px);
  }

  @media (max-width: 860px) {
    .sp-overview-grid,
    .sp-scope-layout {
      grid-template-columns: 1fr;
    }

    .sp-overview-head,
    .sp-deliverables {
      position: static;
    }
  }
</style>
