---
import { sectors } from "../data/site";
---

<section class="section sectors" id="sectors">
  <div class="container">
    <div class="sectors-header" data-reveal>
      <div>
        <span class="kicker">Sectors served</span>
        <h2 class="section-title">Trusted where power cannot fail</h2>
      </div>
      <p class="section-lede">
        We work across the industries that depend on resilient high-voltage
        infrastructure — from grid operators to mission-critical facilities.
      </p>
    </div>

    <div class="sectors-grid">
      <div class="sectors-figure" data-reveal aria-hidden="true">
        <img
          src="/images/sector-grid.jpg"
          alt=""
          loading="lazy"
          width="1306"
          height="743"
        />
        <span class="figure-tag">Grid substation — photograph</span>
      </div>
      {
        sectors.map((s) => (
          <article class="sector-card" data-reveal>
            <span class="sector-icon" aria-hidden="true" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sectors {
    background: var(--surface-2);
    transition: background-color 0.35s ease;
  }

  .sectors-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: end;
  }

  .sectors-header .section-lede {
    margin-top: 0;
    justify-self: end;
  }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.1rem;
    margin-top: 2.6rem;
  }

  .sectors-figure {
    position: relative;
    min-height: 200px;
    border-radius: var(--r-md);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--card-shadow);
  }

  .sectors-figure img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .figure-tag {
    position: absolute;
    left: 1.3rem;
    bottom: 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #eef4fb;
    text-shadow: 0 1px 6px rgba(6, 13, 24, 0.7);
  }

  .sector-card {
    padding: 1.4rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    box-shadow: var(--card-shadow);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .sector-card:hover {
    transform: translateY(-4px);
    border-color: var(--blue);
  }

  .sector-icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 10px;
    background: var(--blue-soft);
    color: var(--blue);
  }

  .sector-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0.9rem 0 0.4rem;
  }

  .sector-card p {
    font-size: 0.93rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .sectors-header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .sectors-header .section-lede {
      justify-self: start;
    }
  }
</style>
