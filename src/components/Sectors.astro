---
const sectors = [
  {
    name: "Utilities & Power Distribution",
    desc: "Network reinforcement, substation upgrades and utility interface works for distribution companies.",
  },
  {
    name: "Industrial & Manufacturing",
    desc: "Reliable MV/LV power for plants where downtime is measured in lost production.",
  },
  {
    name: "Oil, Gas & Energy",
    desc: "Electrical infrastructure for processing facilities, terminals and pipeline assets.",
  },
  {
    name: "Commercial & Real Estate",
    desc: "Dedicated 11/33kV supplies, standby schemes and building distribution for major developments.",
  },
  {
    name: "Renewables & IPPs",
    desc: "Grid connection, collector substations and export infrastructure for independent generators.",
  },
  {
    name: "Data Centres & Critical Facilities",
    desc: "Resilient power architectures where availability is non-negotiable.",
  },
];

const renewablesImage =
  "https://images.unsplash.com/photo-1467533003447-e295ff1b0435?auto=format&fit=crop&w=1400&q=70";
---

<section class="section sectors" id="sectors">
  <div class="container">
    <div class="sectors-header" data-reveal>
      <div>
        <span class="kicker">Where we work</span>
        <h2 class="section-title">Sectors we serve</h2>
      </div>
      <p class="section-lede">
        Wherever electrical infrastructure is critical to the business behind
        it, Caxten has the competence to deliver.
      </p>
    </div>

    <div class="sectors-grid">
      <figure class="sectors-figure" data-reveal>
        <img
          src={renewablesImage}
          alt="Wind turbines on a ridge at dusk"
          loading="lazy"
        />
      </figure>
      {
        sectors.map((s) => (
          <article class="sector-card" data-reveal>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sectors {
    background: var(--surface-2);
    transition: background-color 0.35s ease;
  }

  .sectors-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: end;
  }

  .sectors-header .section-lede {
    margin-top: 0;
    justify-self: end;
  }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    margin-top: 3.5rem;
  }

  .sectors-figure {
    grid-row: span 2;
    margin: 0;
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }

  .sectors-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sector-card {
    padding: 1.8rem 1.7rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .sector-card:hover {
    transform: translateY(-4px);
    border-color: var(--blue);
  }

  .sector-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.55rem;
  }

  .sector-card p {
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .sectors-header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .sectors-header .section-lede {
      justify-self: start;
    }

    .sectors-grid {
      grid-template-columns: 1fr 1fr;
    }

    .sectors-figure {
      grid-column: span 2;
      grid-row: auto;
      max-height: 260px;
    }
  }

  @media (max-width: 560px) {
    .sectors-grid {
      grid-template-columns: 1fr;
    }

    .sectors-figure {
      grid-column: span 1;
    }
  }
</style>
