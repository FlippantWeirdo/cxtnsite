---
import { voltages } from "../data/site";
---

<section class="section capabilities" id="capabilities">
  <div class="container cap-layout">
    <div class="cap-content">
      <div data-reveal>
        <span class="kicker">Voltage capability</span>
        <h2 class="section-title">
          Certified across the full distribution and transmission range
        </h2>
      </div>

      <ul class="cap-list">
        {
          voltages.map((l) => (
            <li class="cap-row" data-reveal>
              <div class="cap-head">
                <span class="cap-kv">{l.kv}</span>
                <div>
                  <span class="cap-band">{l.band}</span>
                  <p class="cap-desc">{l.desc}</p>
                </div>
              </div>
              <div class="cap-track">
                <span
                  class="cap-bar"
                  data-bar
                  style={`--bar-width:${l.width}%`}
                />
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <figure class="cap-figure" data-reveal>
      <img
        src="/images/voltage-substation.jpg"
        alt="Outdoor 33kV air-insulated switchyard at a primary substation"
        loading="lazy"
        width="1006"
        height="1600"
      />
      <figcaption>
        <span class="fig-mono">FIG.01</span> — 33kV air-insulated switchyard,
        primary substation
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .capabilities {
    background: var(--surface-2);
    transition: background-color 0.35s ease;
  }

  .cap-layout {
    display: grid;
    grid-template-columns: 1fr minmax(240px, 320px);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }

  .cap-list {
    list-style: none;
    margin: 1.8rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.4rem;
  }

  .cap-row {
    border-top: 1px solid var(--line);
    padding-top: 1.1rem;
  }

  .cap-head {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1.4rem;
    align-items: baseline;
  }

  .cap-kv {
    font-family: var(--font-mono);
    font-size: 1.7rem;
    font-weight: 600;
    color: var(--heading);
  }

  .cap-band {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
  }

  .cap-desc {
    margin-top: 0.25rem;
    font-size: 0.96rem;
    color: var(--text-muted);
  }

  .cap-track {
    margin-top: 0.6rem;
    height: 6px;
    border-radius: 999px;
    background: var(--line-soft);
    overflow: hidden;
  }

  .cap-bar {
    display: block;
    height: 100%;
    width: var(--bar-width);
    border-radius: 999px;
    background: var(--blue);
    transform-origin: left center;
  }

  .js .cap-bar {
    transform: scaleX(0);
  }

  .js.reduced-motion .cap-bar {
    transform: none;
  }

  .cap-figure {
    margin: 0;
  }

  .cap-figure img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1006 / 1600;
    object-fit: cover;
    border-radius: var(--r-lg);
    border: 1px solid var(--line);
    box-shadow: var(--card-shadow);
  }

  .cap-figure figcaption {
    margin-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .fig-mono {
    font-family: var(--font-mono);
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .cap-layout {
      grid-template-columns: 1fr;
    }

    .cap-figure {
      max-width: 340px;
      margin-inline: auto;
    }
  }
</style>
