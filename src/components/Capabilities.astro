---
const substationImage =
  "https://images.unsplash.com/photo-1509390144018-eeaf65052242?auto=format&fit=crop&w=1400&q=70";

const levels = [
  {
    kv: "0.4",
    band: "Low voltage",
    desc: "Distribution boards, motor control centres, LV switchgear and building reticulation.",
    width: 22,
  },
  {
    kv: "11",
    band: "Medium voltage",
    desc: "Ring main units, MV switchgear, distribution transformers and feeder networks.",
    width: 46,
  },
  {
    kv: "33",
    band: "Medium voltage",
    desc: "Primary distribution substations, power transformers and protection schemes.",
    width: 72,
  },
  {
    kv: "66",
    band: "High voltage",
    desc: "Sub-transmission substations, grid connections and utility interface works.",
    width: 100,
  },
];
---

<section class="section capabilities" id="capabilities">
  <div class="container cap-layout">
    <div class="cap-content">
      <div data-reveal>
        <span class="kicker">Voltage capability</span>
        <h2 class="section-title">From the panel board to the grid</h2>
        <p class="section-lede">
          We work safely and competently across every voltage class our
          clients operate — with the engineering discipline each level
          demands.
        </p>
      </div>

      <ul class="cap-list">
        {
          levels.map((l) => (
            <li class="cap-row" data-reveal>
              <div class="cap-head">
                <span class="cap-kv">
                  {l.kv}<small>kV</small>
                </span>
                <span class="cap-band">{l.band}</span>
              </div>
              <p class="cap-desc">{l.desc}</p>
              <div class="cap-track">
                <span
                  class="cap-bar"
                  data-bar
                  style={`--bar-width:${l.width}%`}
                />
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <figure class="cap-figure" data-reveal>
      <img
        src={substationImage}
        alt="High voltage substation transformer against a clear sky"
        loading="lazy"
      />
      <figcaption>
        <span class="fig-mono">33/11kV</span> primary substation — supply,
        install &amp; commission
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .cap-layout {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: center;
  }

  .cap-list {
    list-style: none;
    margin: 3rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.9rem;
  }

  .cap-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .cap-kv {
    font-family: var(--font-mono);
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--heading);
  }

  .cap-kv small {
    font-size: 0.9rem;
    color: var(--blue);
    margin-left: 0.15rem;
  }

  .cap-band {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
  }

  .cap-desc {
    margin-top: 0.45rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 52ch;
  }

  .cap-track {
    margin-top: 0.8rem;
    height: 4px;
    border-radius: 2px;
    background: var(--surface-2);
    overflow: hidden;
  }

  .cap-bar {
    display: block;
    height: 100%;
    width: var(--bar-width);
    border-radius: 2px;
    background: linear-gradient(90deg, var(--blue), var(--amber));
    transform-origin: left center;
  }

  .js .cap-bar {
    transform: scaleX(0);
  }

  .js.reduced-motion .cap-bar {
    transform: none;
  }

  .cap-figure {
    margin: 0;
  }

  .cap-figure img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: var(--card-shadow);
  }

  .cap-figure figcaption {
    margin-top: 0.9rem;
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .fig-mono {
    font-family: var(--font-mono);
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .cap-layout {
      grid-template-columns: 1fr;
    }

    .cap-figure img {
      aspect-ratio: 16 / 10;
    }
  }
</style>
