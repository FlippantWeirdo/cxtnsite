---
// Caxten wordmark with a voltage-bolt hex mark.
---

<a href="/" class="logo" aria-label="Caxten Engineering — home">
  <svg
    class="logo-mark"
    width="34"
    height="38"
    viewBox="0 0 34 38"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M17 1.5 32 10v18L17 36.5 2 28V10L17 1.5Z"
      stroke="var(--blue)"
      stroke-width="2"
    ></path>
    <path d="M19.5 8 12 20.5h5L14.5 30 22 17.5h-5L19.5 8Z" fill="var(--amber)"
    ></path>
  </svg>
  <span class="logo-text">
    CAXTEN
    <small>ENGINEERING</small>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.14em;
    line-height: 1;
    color: var(--heading);
  }

  .logo-text small {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.42em;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }
</style>
