---
// Caxten brand logo — the "C" orbit mark plus the wordmark.
// Height is set inline so it can never be overridden by the image's
// intrinsic size or a stale scoped-CSS bundle.
---

<a href="/" class="logo" aria-label="Caxten Engineering — home">
  <img
    class="logo-mark"
    src="/images/logo.png"
    alt="Caxten Engineering logo"
    decoding="async"
    style="height: 4.6rem; width: auto; display: block; object-fit: contain;"
  />
  <span class="logo-text">
    CAXTEN
    <small>ENGINEERING</small>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.14em;
    line-height: 1;
    color: var(--heading);
  }

  .logo-text small {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.42em;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }
</style>
