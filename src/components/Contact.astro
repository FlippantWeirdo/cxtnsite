---
// NOTE: placeholder contact details — replace with the client's real
// address, phone and email. The form is presentational for now; wire it
// to a form service (Formspree, Basin, etc.) or an API route later.

interface Props {
  /** When true, adds top padding so the section clears the fixed header
      as the first element on a dedicated page (e.g. /contact). */
  standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section class:list={["section", "contact", { standalone }]} id="contact">
  <div class="container contact-layout">
    <div class="contact-info" data-reveal>
      <span class="kicker">Get in touch</span>
      <h2 class="section-title">Let's discuss your next project</h2>
      <p class="section-lede">
        Whether you're planning a new substation, upgrading a network or need
        a maintenance partner for existing assets — speak to our engineers.
      </p>

      <dl class="contact-details">
        <div>
          <dt>Email</dt>
          <dd><a href="mailto:info@caxten.com">info@caxten.com</a></dd>
        </div>
        <div>
          <dt>Phone</dt>
          <dd><a href="tel:+2340000000000">+234 (0) 000 000 0000</a></dd>
        </div>
        <div>
          <dt>Office</dt>
          <dd>Head office address, City, Country</dd>
        </div>
        <div>
          <dt>Emergency callout</dt>
          <dd>24/7 fault response for maintenance clients</dd>
        </div>
      </dl>
    </div>

    <form class="contact-form" data-reveal>
      <div class="form-row">
        <label>
          Full name
          <input type="text" name="name" placeholder="Your name" required />
        </label>
        <label>
          Email address
          <input type="email" name="email" placeholder="you@company.com" required />
        </label>
      </div>
      <label>
        Company
        <input type="text" name="company" placeholder="Company name" />
      </label>
      <label>
        Project details
        <textarea
          name="message"
          rows="5"
          placeholder="Tell us about the works — voltage level, scope, location, timeline…"
          required></textarea>
      </label>
      <button type="submit" class="btn btn-primary">Send enquiry</button>
      <p class="form-note" data-form-note hidden>
        Thank you — your enquiry has been noted. (Demo form: not yet connected.)
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact-form");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.querySelector<HTMLElement>("[data-form-note]")?.removeAttribute("hidden");
  });
</script>

<style>
  /* Clears the fixed header when Contact is the first element on a page. */
  .contact.standalone {
    padding-top: calc(4.75rem + clamp(3rem, 7vw, 6rem));
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: start;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.8rem 2rem;
    margin: 2.4rem 0 0;
  }

  .contact-details dt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 0.35rem;
  }

  .contact-details dd {
    margin: 0;
    font-size: 0.98rem;
    color: var(--text);
  }

  .contact-details a:hover {
    color: var(--blue);
  }

  .contact-form {
    display: grid;
    gap: 1.2rem;
    padding: 2.2rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-lg);
    box-shadow: var(--card-shadow);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--heading);
  }

  input,
  textarea {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    padding: 0.8rem 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
    font-weight: 400;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px var(--blue-soft);
  }

  textarea {
    resize: vertical;
  }

  .contact-form .btn {
    justify-self: start;
  }

  .form-note {
    font-size: 0.88rem;
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .form-row,
    .contact-details {
      grid-template-columns: 1fr;
    }
  }
</style>
