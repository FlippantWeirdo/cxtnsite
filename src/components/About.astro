---
import { credibility } from "../data/site";
---

<section class="section about" id="about">
  <div class="container about-layout">
    <div class="about-media" data-reveal>
      <img
        class="about-img-main"
        src="/images/about-team.jpg"
        alt="Caxten engineers on site during a medium-voltage substation installation"
        loading="lazy"
        width="1305"
        height="734"
      />
      <img
        class="about-img-inset"
        src="/images/service-install.jpg"
        alt="Caxten technician carrying out on-site electrical installation work"
        loading="lazy"
        width="1008"
        height="756"
      />
    </div>

    <div class="about-content" data-reveal>
      <span class="kicker">Who we are</span>
      <h2 class="section-title">Disciplined engineering. Dependable power.</h2>
      <p class="section-lede">
        Established in 2008, Caxten is an indigenous electrical engineering
        contractor specialising in 33kV, 11kV and 0.4kV power systems. Led by
        COREN-registered engineers with over 20 years of experience, we supply,
        install, test and commission substation and distribution projects to
        utility specification — safely, on programme, and fully documented.
      </p>
      <ul class="about-points">
        {
          credibility.map((c) => (
            <li>
              <span class="check" aria-hidden="true">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.4"><path d="M20 6 9 17l-5-5" /></svg>
              </span>
              {c}
            </li>
          ))
        }
      </ul>
      <a href="/about" class="btn btn-primary about-cta">
        About Caxten
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--surface-2);
    transition: background-color 0.35s ease;
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }

  .about-media {
    position: relative;
  }

  .about-img-main {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1305 / 734;
    object-fit: cover;
    border-radius: var(--r-lg);
    border: 1px solid var(--line);
    box-shadow: var(--card-shadow);
  }

  /* Landscape detail shot tucked into the bottom-right corner, overlapping
     the main image and poking out below and to the right. */
  .about-img-inset {
    position: absolute;
    right: -6%;
    bottom: -16%;
    width: 46%;
    height: auto;
    aspect-ratio: 1008 / 756;
    object-fit: cover;
    border-radius: var(--r-lg);
    border: 7px solid var(--surface-2);
    box-shadow: var(--card-shadow);
  }

  .about-points {
    margin: 1.8rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.9rem;
  }

  .about-points li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
  }

  .check {
    flex: none;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: var(--blue-soft);
    color: var(--blue);
  }

  .about-cta {
    margin-top: 2rem;
  }

  @media (max-width: 900px) {
    .about-layout {
      grid-template-columns: 1fr;
    }

    .about-media {
      margin-bottom: 4.5rem;
    }

    /* keep the inset inside the viewport on narrow screens */
    .about-img-inset {
      right: 0;
      bottom: -12%;
      width: 42%;
    }
  }
</style>
