---
import { services } from "../data/services";
---

<section class="section services" id="services">
  <div class="container">
    <div data-reveal>
      <span class="kicker">What we do</span>
      <h2 class="section-title">Six disciplines, one accountable delivery partner</h2>
      <p class="section-lede">
        From procurement to lifetime maintenance, every stage of a
        high-voltage project handled under a single chain of responsibility.
      </p>
    </div>

    <div class="services-grid">
      {
        services.map((s) => (
          <a class="service-card" href={`/services/${s.slug}`} data-reveal>
            <span class="service-icon" aria-hidden="true" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.summary}</p>
            <span class="service-more">
              Learn more
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.1rem;
    margin-top: 2.6rem;
  }

  .service-card {
    display: block;
    position: relative;
    padding: 1.6rem 1.5rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    box-shadow: var(--card-shadow);
    color: inherit;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--blue);
  }

  .service-card:focus-visible {
    outline: 2px solid var(--blue);
    outline-offset: 3px;
  }

  .service-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 12px;
    background: var(--blue-soft);
    color: var(--blue);
  }

  .service-card h3 {
    font-size: 1.22rem;
    font-weight: 600;
    margin: 1.1rem 0 0.5rem;
  }

  .service-card p {
    font-size: 0.98rem;
    color: var(--text-muted);
  }

  .service-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--blue);
  }

  .service-more svg {
    transition: transform 0.25s ease;
  }

  .service-card:hover .service-more svg {
    transform: translateX(4px);
  }
</style>
