---
const heroImage =
  "https://images.unsplash.com/photo-1413882353314-73389f63b6fd?auto=format&fit=crop&w=2000&q=70";
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <img src={heroImage} alt="" fetchpriority="high" data-hero-img />
    <div class="hero-overlay"></div>
    <svg class="hero-grid" aria-hidden="true">
      <defs>
        <pattern id="grid" width="56" height="56" patternUnits="userSpaceOnUse">
          <path
            d="M56 0H0v56"
            fill="none"
            stroke="rgba(160,195,240,0.1)"
            stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"></rect>
    </svg>
  </div>

  <div class="container hero-inner">
    <p class="hero-kicker" data-hero="0">
      HV &amp; MV Electrical Engineering
    </p>
    <h1 class="hero-title">
      <span class="hero-line" data-hero="1">Power infrastructure,</span>
      <span class="hero-line" data-hero="2">engineered <em>end&#8209;to&#8209;end.</em></span>
    </h1>
    <p class="hero-sub" data-hero="3">
      Caxten delivers equipment supply, installation, testing, commissioning
      and maintenance of low &amp; medium voltage electrical facilities — from
      0.4kV distribution networks to 66kV substations.
    </p>
    <div class="hero-actions" data-hero="4">
      <a href="#services" class="btn btn-primary">
        Explore our services
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"></path></svg>
      </a>
      <a href="/contact" class="btn btn-ghost hero-ghost">Speak to an engineer</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100svh;
    padding-top: 6rem;
    overflow: hidden;
    color: var(--on-navy);
  }

  .hero-bg,
  .hero-bg img,
  .hero-overlay,
  .hero-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-bg img {
    object-fit: cover;
    will-change: transform;
  }

  .hero-overlay {
    background:
      linear-gradient(115deg, var(--hero-overlay-a) 30%, var(--hero-overlay-b) 75%),
      linear-gradient(to top, var(--hero-overlay-a), transparent 45%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: 4rem;
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.6rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6.2vw, 4.6rem);
    font-weight: 650;
    color: #ffffff;
    letter-spacing: -0.02em;
    max-width: 16ch;
  }

  .hero-line {
    display: block;
    overflow: hidden;
  }

  .hero-title em {
    font-style: normal;
    color: var(--amber);
  }

  .hero-sub {
    max-width: 56ch;
    margin-top: 1.8rem;
    font-size: 1.1rem;
    color: var(--on-navy-muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.6rem;
  }

  .hero-ghost {
    color: #ffffff;
  }

  .hero-ghost:hover {
    border-color: var(--amber);
    color: var(--amber);
  }
</style>
