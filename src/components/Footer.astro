---
import Logo from "./Logo.astro";
import { services } from "../data/services";
import { company, contact } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <Logo />
      <p>{company.blurb}</p>
    </div>

    <nav class="footer-col" aria-label="Services">
      <h3>Services</h3>
      <ul>
        {
          services.map((s) => (
            <li>
              <a href={`/services/${s.slug}`}>{s.title}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="footer-col" aria-label="Company">
      <h3>Company</h3>
      <ul>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/#sectors">Sectors</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <div class="footer-col">
      <h3>Contact</h3>
      <ul>
        <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        <li><a href={`tel:${contact.phoneHref}`}>{contact.phone}</a></li>
        <li>
          {contact.addressLines[0]}<br />{contact.addressLines[1]}
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {company.legalName} · RC {company.rc}</p>
    <p class="footer-tag">{company.tagline}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: #c2d1e4;
    padding-top: clamp(3.5rem, 6vw, 5rem);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .footer-brand p {
    margin-top: 1rem;
    max-width: 34ch;
    font-size: 0.95rem;
    color: #8ba1bc;
  }

  .footer-col h3 {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5b9bff;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
    font-size: 0.94rem;
    color: #c2d1e4;
  }

  .footer-col a {
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: #eef4fb;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1.4rem;
    border-top: 1px solid rgba(200, 220, 245, 0.14);
    font-size: 0.85rem;
    color: #8ba1bc;
  }

  .footer-tag {
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  /* The logo wordmark sits on a dark surface here. */
  .footer-brand :global(.logo-text) {
    color: #eef4fb;
  }

  .footer-brand :global(.logo-text small) {
    color: #8ba1bc;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
