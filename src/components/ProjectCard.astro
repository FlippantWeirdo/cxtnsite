---
import type { Project } from "../data/site";

interface Props {
  project: Project;
  /** "home" shows the result + year; "full" shows the client + result·year. */
  variant?: "home" | "full";
}

const { project, variant = "home" } = Astro.props;
---

<article class="project-card" data-card data-reveal>
  <div class="project-media">
    <img src={project.image} alt={project.title} loading="lazy" />
    <span class="project-kv">{project.kv}</span>
  </div>
  <div class="project-body">
    <div class="project-meta">
      <span class="project-sector">{project.sector}</span>
      <span aria-hidden="true">·</span>
      <span>{project.location}</span>
    </div>
    <h3>{project.title}</h3>
    <p>{project.desc}</p>
    <div class="project-foot">
      {
        variant === "home" ? (
          <>
            <span class="project-result">{project.result}</span>
            {project.year && <span class="project-year">{project.year}</span>}
          </>
        ) : (
          <>
            <span class="project-result">{project.client}</span>
            <span class="project-year dotted">
              <span class="dot" aria-hidden="true" />
              {project.result}
              {project.year && ` · ${project.year}`}
            </span>
          </>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--r-md);
    overflow: hidden;
    box-shadow: var(--card-shadow);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--blue);
  }

  .project-media {
    position: relative;
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid var(--line-soft);
    overflow: hidden;
  }

  .project-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-kv {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #0b2545;
    background: var(--amber);
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
  }

  .project-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.4rem;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .project-sector {
    color: var(--blue);
  }

  .project-body h3 {
    font-size: 1.2rem;
    margin: 0.65rem 0 0.5rem;
  }

  .project-body p {
    margin: 0 0 1.1rem;
    color: var(--text-muted);
    font-size: 0.93rem;
  }

  .project-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line-soft);
    padding-top: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .project-result {
    color: var(--heading);
    font-weight: 500;
  }

  .project-year {
    color: var(--text-muted);
  }

  .project-year.dotted {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--amber);
  }
</style>
